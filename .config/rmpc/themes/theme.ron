#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    show_song_table_header: false,
    draw_borders: true,
    browser_column_widths: [20, 38, 42],
    text_color: "#FFFFFF",
    tab_bar: (
        enabled: true,
        active_style: (fg: "#FFFFFF", modifiers: "Bold"),
        inactive_style: (fg: "#A36565", modifiers: ""),
    ),
    highlighted_item_style: (fg: "#A3656A", modifiers: "Bold"),
    current_item_style: (fg: "#961520", bg: "#531518", modifiers: "Bold"),
    borders_style: (fg: "#A36565", modifiers: "Bold"),
    highlight_border_style: (fg: "#A36565"),
    symbols: (song: "󰝚 ", dir: " ", marker: "* ", ellipsis: "..."),
    progress_bar: (
        symbols: ["█", "█", "█"],
        track_style: (fg: "#120809"),
        elapsed_style: (fg: "#F0AAB0"),
        thumb_style: (fg: "#F0AAB0"),
    ),
    scrollbar: (
        symbols: ["", "", "", ""],
        track_style: (fg: "#A36565"),
        ends_style: (fg: "#A36565"),
        thumb_style: (fg: "#A36565"),
    ),
    song_table_format: [
        (
            prop: (kind: Property(Title), style: (fg: "#F0AAB0"),
                highlighted_item_style: (fg: "#120809", modifiers: "Bold"),
                default: (kind: Property(Filename), style: (fg: "gray"),)
            ),
            width: "70%",
        ),
        (
            prop: (kind: Property(Album), style: (fg: "#A36565"),
                default: (kind: Text("Unknown Album"), style: (fg: "#7D4B4B"))
            ),
            width: "30%",
        ),
    ],
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "3",
                pane: Pane(Tabs),
            ),
            (
                size: "4",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "100%",
                            pane: Split(
                                direction: Vertical,
                                panes: [
                                    (
                                        size: "4",
                                        borders: "ALL",
                                        pane: Pane(Header),
                                    ),
                                ]
                            )
                        ),
                    ]
                ),
            ),
            (
                size: "100%",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "100%",
                            borders: "NONE",
                            pane: Pane(TabContent),
                        ),
                    ]
                ),
            ),
            (
                size: "3",
                borders: "TOP | BOTTOM",
                pane: Pane(ProgressBar),
            ),
        ],
    ),
    header: (
        rows: [
            (
                left: [
                    (kind: Property(Status(StateV2(playing_label: " Playing", paused_label: " Paused", stopped_label: "󰓛 Stopped"))), style: (fg: "#961520", modifiers: "Bold")),
                ],
                center: [
                    (kind: Property(Song(Title)), style: (fg: "#FFFFFF",modifiers: "Bold"),
                        default: (kind: Property(Song(Filename)), style: (fg: "#FFFFFF",modifiers: "Bold"))
                    )
                ],
                right: [
                    (kind: Text("Vol: "), style: (fg: "#961520", modifiers: "Bold")),
                    (kind: Property(Status(Volume)), style: (fg: "#961520", modifiers: "Bold")),
                    (kind: Text("% "), style: (fg: "#961520", modifiers: "Bold"))
                ]
            ),
            (
                left: [
                    (kind: Property(Status(Elapsed)),style: (fg: "#FFFFFF")),
                    (kind: Text("/"),style: (fg: "#A36565")),
                    (kind: Property(Status(Duration)),style: (fg: "#FFFFFF")),
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "#961520", modifiers: "Bold"),
                        default: (kind: Text("Unknown Artist"), style: (fg: "#e0af68", modifiers: "Bold"))
                    ),
                ],
                right: [
                    (kind: Property(Status(RepeatV2(on_label: "󰑖", off_label: "󰑖", on_style: (fg: "#FFFFFF"), off_style: (fg: "#A36565"))))),
                    (kind: Text("/"),style: (fg: "#A36565")),
                    (kind: Property(Status(RandomV2(on_label: "", off_label: "", on_style: (fg: "#FFFFFF"), off_style: (fg: "#A36565"))))),
                    (kind: Text("/"),style: (fg: "#A36565")),
                    (kind: Property(Status(ConsumeV2(on_label: "󰮯", off_label: "󰮯", oneshot_label: "O", on_style: (fg: "#FFFFFF"), off_style: (fg: "#A36565"))))),
                    (kind: Text("/"),style: (fg: "#A36565")),
                    (kind: Property(Status(SingleV2(on_label: "S ", off_label: "S ", oneshot_label: "O ", on_style: (fg: "#FFFFFF"), off_style: (fg: "#A36565"))))),
                ]
            ),
        ],
    ),
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Track)),
                (kind: Text(" ")),
            ])
        ),
        (
            kind: Group([
                (kind: Property(Artist)),
                (kind: Text(" - ")),
                (kind: Property(Title)),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
)
